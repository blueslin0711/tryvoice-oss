# Include pre-built frontend assets in source distributions.
# These are generated by `npm run build` before packaging.
recursive-include apps/host-runtime/backend/static-dist *

# Include wakeword models (exclude archive/ and deploy scripts)
recursive-include apps/host-runtime/backend/wakeword/oww *.onnx *.onnx.data *.json
recursive-include apps/host-runtime/backend/wakeword/sherpa-kws *
include apps/host-runtime/backend/wakeword/*.ppn
include apps/host-runtime/backend/wakeword/*.pv
include apps/host-runtime/backend/wakeword/*.onnx
include apps/host-runtime/backend/wakeword/*.json
include apps/host-runtime/backend/wakeword/LICENSE.txt
recursive-exclude apps/host-runtime/backend/wakeword/archive *

# Include avatars
recursive-include apps/host-runtime/backend/avatars *

# Include default config files
include apps/host-runtime/backend/*.json
include apps/host-runtime/backend/env.example

# Exclude build artifacts and secrets
exclude .env
exclude .env.*
global-exclude __pycache__
global-exclude *.pyc
global-exclude *.pyo
global-exclude .DS_Store
