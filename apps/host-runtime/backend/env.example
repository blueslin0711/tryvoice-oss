# TryVoice configuration
# Copy this to project-root .env and fill in your keys.
# Run `tryvoice --setup` for an interactive wizard.

# ═══════════════════════════════════════════════════════════
# Adapter selection (REQUIRED)
# ═══════════════════════════════════════════════════════════
# Available adapters (must be installed via pip):
#   echo          — Demo/test mode, no external API needed (built-in)
#   openai-compat — Any OpenAI-compatible API (DeepSeek, Ollama, OpenAI, etc.)
#   anthropic     — Anthropic Claude API (native, recommended)
#   openclaw      — OpenClaw Agent Gateway
TRYVOICE_ACTIVE_ADAPTER=echo

# ═══════════════════════════════════════════════════════════
# OpenAI-compatible adapter (openai-compat)
# ═══════════════════════════════════════════════════════════
# LLM_API_BASE_URL=http://localhost:11434/v1       # Ollama default
# LLM_API_BASE_URL=https://api.deepseek.com/v1    # DeepSeek
# LLM_API_BASE_URL=https://api.openai.com/v1      # OpenAI
# LLM_API_KEY=sk-xxx                               # optional for local models
# LLM_MODEL=gpt-3.5-turbo                          # model name
# LLM_SYSTEM_PROMPT=You are a helpful assistant.   # system prompt
# LLM_MAX_HISTORY=50                                # max history messages per session
# Advanced: model parameter presets (auto-detected from LLM_MODEL if unset)
# Available: default, openai-gpt4o, openai-o1, deepseek, ollama, qwen, moonshot, claude-compat, gemini-compat
# LLM_PRESET=deepseek
# LLM_TEMPERATURE=0.7                              # override preset default
# LLM_TOP_P=1.0
# LLM_MAX_TOKENS=4096
# LLM_FREQUENCY_PENALTY=0
# LLM_PRESENCE_PENALTY=0
# LLM_TIMEOUT=120                                  # HTTP timeout in seconds

# ═══════════════════════════════════════════════════════════
# Anthropic Claude adapter (anthropic)
# ═══════════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-xxx                    # Anthropic API key (required)
# ANTHROPIC_MODEL=claude-sonnet-4-6-20250514      # Model (default: Sonnet 4.6)
# ANTHROPIC_BASE_URL=https://api.anthropic.com    # API base URL
# LLM_SYSTEM_PROMPT=You are a helpful assistant.  # system prompt
# LLM_MAX_HISTORY=50                               # max history messages per session
# LLM_TEMPERATURE=0.7                              # temperature
# LLM_MAX_TOKENS=4096                              # max output tokens
# LLM_TIMEOUT=120                                  # HTTP timeout in seconds

# ═══════════════════════════════════════════════════════════
# OpenClaw adapter (openclaw)
# ═══════════════════════════════════════════════════════════
# AGENT_GATEWAY_URL=http://localhost:18789
# AGENT_GATEWAY_TOKEN=your_token
# Optional: override session tool names if your gateway uses aliases.
# OPENCLAW_TOOL_SESSIONS_SEND=sessions_send
# OPENCLAW_TOOL_SESSIONS_HISTORY=sessions_history
# Optional: session namespace (defaults are fine for most users)
# OPENCLAW_SESSION_AGENT_ID=main
# OPENCLAW_SESSION_NAMESPACE=voice-chat
# OPENCLAW_SESSION_SCOPE=shared

# ═══════════════════════════════════════════════════════════
# Speech-to-Text (optional — browser Web Speech API as fallback)
# ═══════════════════════════════════════════════════════════
# GROQ_API_KEY=your_groq_api_key

# ═══════════════════════════════════════════════════════════
# Text-to-Speech
# ═══════════════════════════════════════════════════════════
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# Optional: Azure Speech (browser-direct TTS, lower latency on mobile)
# AZURE_SPEECH_KEY=your_azure_speech_key
# AZURE_SPEECH_REGION=eastus

# ═══════════════════════════════════════════════════════════
# Wake Word (optional)
# ═══════════════════════════════════════════════════════════
# Default engine: OpenWakeWord (free, 6 built-in keywords, zero config)
# Picovoice (more accurate, requires API key + device registration):
# PICOVOICE_ACCESS_KEY=your_picovoice_access_key
# PICOVOICE_ACCESS_KEY_MOBILE=your_mobile_picovoice_access_key
# To expose Picovoice key to browser clients, explicitly enable:
# TRYVOICE_EXPOSE_PICOVOICE_KEY=1

# ═══════════════════════════════════════════════════════════
# Access Control (optional)
# ═══════════════════════════════════════════════════════════
# TRYVOICE_ACCESS_PASSWORD=your_password
# TRYVOICE_ACCESS_COOKIE_NAME=tryvoice_access
# TRYVOICE_ACCESS_SESSION_TTL_SECONDS=604800
# TRYVOICE_ACCESS_SESSION_SECRET=long_random_secret

# ═══════════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════════
PORT=7860
# Browser-direct STT key exposure is disabled by default for safety.
# TRYVOICE_EXPOSE_BROWSER_STT_KEY=1

# ═══════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════
# SERVER_LOG_LEVEL=INFO                              # DEBUG, INFO, WARNING, ERROR
# SERVER_LOG_FORMAT=text                             # text (human-readable) or json (structured)
# SERVER_LOG_ROTATION=20 MB
# SERVER_LOG_RETENTION=7 days

# ═══════════════════════════════════════════════════════════
# History Retention (optional — keep forever by default)
# ═══════════════════════════════════════════════════════════
# HISTORY_RETENTION_DAYS=90                          # auto-prune messages older than N days (0 = disabled)
# HISTORY_MAX_MESSAGES_PER_BOT=1000                  # max messages per bot (0 = unlimited)

# ═══════════════════════════════════════════════════════════
# Optional: Telegram mirror (disabled by default)
# ═══════════════════════════════════════════════════════════
# OPENCLAW_TELEGRAM_MIRROR_ENABLED=0

# ═══════════════════════════════════════════════════════════
# Optional: user data directory (default: ~/.tryvoice)
# ═══════════════════════════════════════════════════════════
# TRYVOICE_USER_DATA_DIR=~/.tryvoice
