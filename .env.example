# ── Adapter (REQUIRED — pick one) ──────────────────────────────────────────
# Options: echo, openai-compat, anthropic, openclaw
# "echo" needs no API key — good for testing
TRYVOICE_ACTIVE_ADAPTER=echo

# ── OpenAI-compatible adapter (if using openai-compat) ─────────────────────
# LLM_API_BASE_URL=https://api.deepseek.com/v1   # or http://localhost:11434/v1 for Ollama
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# ── Anthropic adapter (if using anthropic) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenClaw adapter (if using openclaw) ───────────────────────────────────
# OPENCLAW_GATEWAY_URL=http://localhost:18789
# OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# ── LLM settings (optional) ───────────────────────────────────────────────
# LLM_SYSTEM_PROMPT=You are a helpful AI assistant.
# LLM_MAX_TOKENS=4096

# ── Speech-to-text (optional — falls back to browser Web Speech API) ──────
# STT_MODE=cloud
# GROQ_API_KEY=your_groq_api_key_here

# ── Text-to-speech (optional — defaults to Edge TTS) ──────────────────────
# TTS_MODE=cloud
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ── Azure Speech (optional — browser-direct TTS) ──────────────────────────
# AZURE_SPEECH_KEY=your_azure_speech_key_here
# AZURE_SPEECH_REGION=westus2

# ── Server (optional) ─────────────────────────────────────────────────────
# PORT=7860

# ── Wake word (optional) ──────────────────────────────────────────────────
# PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here
# PICOVOICE_ACCESS_KEY_MOBILE=your_picovoice_access_key_here
# TRYCLAW_EXPOSE_PICOVOICE_KEY=1

# ── Unified session keys (optional — for Web + Telegram sync) ─────────────
# OPENCLAW_SESSION_KEY_MAIN=agent:main:telegram:alexa:direct:YOUR_TELEGRAM_USER_ID
# OPENCLAW_SESSION_KEY_CODER=agent:main:telegram:bumblebee:direct:YOUR_TELEGRAM_USER_ID
# OPENCLAW_SESSION_KEY_VISUAL=agent:main:telegram:jarvis:direct:YOUR_TELEGRAM_USER_ID
# OPENCLAW_SESSION_KEY_TESTER=agent:main:telegram:grasshopper:direct:YOUR_TELEGRAM_USER_ID

# ── Telegram mirror (optional) ────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN_MAIN=your_telegram_bot_token_here
# TELEGRAM_BOT_TOKEN_CODER=your_telegram_bot_token_here
# TELEGRAM_BOT_TOKEN_VISUAL=your_telegram_bot_token_here
# TELEGRAM_BOT_TOKEN_TESTER=your_telegram_bot_token_here
# OPENCLAW_TELEGRAM_MIRROR_ENABLED=1
